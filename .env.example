# -----------------------------
# Backend service configuration
# -----------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/leady
LOG_LEVEL=INFO

# Optional admin emails (comma-separated) for non-role-based admin gates.
LEADBOT_ADMIN_EMAILS=

# Authy-backed auth settings (mapped via nested settings fields)
AUTH__PROVIDER=authy
AUTH__JWT_SECRET=change-me-in-production-minimum-32-chars
AUTH__JWT_TTL_SECONDS=3600
AUTH__GOOGLE_CLIENT_ID=
AUTH__GOOGLE_CLIENT_SECRET=
AUTH__GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --------------------------------
# Frontend service configuration
# --------------------------------
# Server-side NextAuth calls from inside Docker should use the service DNS name.
API_BASE_URL=http://leady-api:8000
# Browser-side requests should still target localhost in local development.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth/Google auth placeholders for local development.
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
