# -----------------------------
# Backend service configuration
# -----------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/leady
LOG_LEVEL=INFO

# Optional admin emails (comma-separated) for /api/auth admin-gated paths.
LEADBOT_ADMIN_EMAILS=

# API auth signing key. If omitted, backend falls back to <app_name>-dev-secret.
AUTH_API_KEY=change-me-in-production

# --------------------------------
# Frontend service configuration
# --------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth/Google auth placeholders for local development.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
